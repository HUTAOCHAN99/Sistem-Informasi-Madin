# Isi ini dengan kredensial project Supabase kamu (Project Settings > API).
#
# NEXT_PUBLIC_SUPABASE_URL dan NEXT_PUBLIC_SUPABASE_ANON_KEY aman dipakai
# di browser (client component), tapi saat ini belum dipakai untuk baca
# data dashboard — dashboard membaca lewat server pakai service role key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# WAJIB DIISI, dan JANGAN PERNAH taruh nilai ini di kode/komponen client.
# Dipakai hanya di server (Server Component / Server Action) lewat
# src/lib/supabase/server.ts untuk baca-tulis penuh ke semua tabel
# (melewati RLS). Ambil dari Project Settings > API > service_role.
SUPABASE_SERVICE_ROLE_KEY=

# Dipakai untuk menandatangani cookie sesi login admin (lihat
# src/lib/auth/session.ts). Ganti dengan string acak yang panjang saat
# deploy ke produksi.
SESSION_SECRET=

# Kredensial login admin (dipakai src/lib/auth/admin-credentials.ts).
ADMIN_EMAIL=
# Hash bcrypt dari password admin. Buat hash baru dengan:
#   node -e "console.log(require('bcryptjs').hashSync('password-baru', 10))"
ADMIN_PASSWORD_HASH=
# Set "true" saat pengembangan supaya kode OTP login ditampilkan langsung
# di response (tidak perlu setup pengiriman email dulu).
OTP_DEV_MODE=
